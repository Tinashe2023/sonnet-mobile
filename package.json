{
  "name": "sonnetmobile",
  "version": "1.0.0",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "npx expo export --platform web --output-dir dist",
    "electron": "electron .",
    "build-electron": "electron-builder"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.9.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "expo": "~55.0.4",
    "expo-av": "^16.0.8",
    "expo-device": "~55.0.9",
    "expo-document-picker": "^55.0.8",
    "expo-file-system": "^55.0.10",
    "expo-image-picker": "^55.0.10",
    "expo-linear-gradient": "~55.0.8",
    "expo-notifications": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "rn-emoji-keyboard": "^1.7.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0"
  },
  "private": true,
  "build": {
    "appId": "com.sonnetmobile.app",
    "productName": "SonnetMobile",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
